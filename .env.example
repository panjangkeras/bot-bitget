# ══════════════════════════════════════════════════════════
#  .env — Bitget Scalping Santai v2.2
# ══════════════════════════════════════════════════════════

# ─── WAJIB: Bitget API ───────────────────────────────────
BITGET_API_KEY=isi_api_key_bitget
BITGET_SECRET_KEY=isi_secret_key_bitget
BITGET_PASSPHRASE=isi_passphrase_bitget

# ─── WAJIB: AI (Cerebras — gratis di cerebras.ai) ────────
GROQ_API_KEY=isi_cerebras_api_key

# ─── WAJIB: Pairs & Modal ────────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
USDT_PER_TRADE=20
MAX_DAILY_LOSS=5

# ─── OPSIONAL: Leverage & Posisi ─────────────────────────
LEVERAGE=10           # max leverage bot boleh pakai (10-30, default 15)
MAX_OPEN_POS=1        # max posisi bersamaan
PRODUCT_TYPE=USDT-FUTURES

# ─── OPSIONAL: Telegram Notifikasi ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── OPSIONAL: Berita (newsapi.org — gratis) ─────────────
NEWS_API_KEY=

# ─── OPSIONAL: Log ───────────────────────────────────────
LOG_LEVEL=           # set ke "quiet" untuk sembunyikan log tidak penting
MIN_CONFIDENCE=0.65  # minimum confidence untuk entry (default 0.65)

# ─── SUPABASE — AI Memory & Trade History ─────────────────
# Buat project gratis di https://supabase.com
# Lalu jalankan supabase_schema.sql di SQL Editor
#
# Cara dapat URL & Key:
#   Supabase Dashboard → Settings → API
#   - "Project URL"  → SUPABASE_URL
#   - "anon public"  → SUPABASE_ANON_KEY
#
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Aktifkan log sinyal AI ke Supabase (untuk audit — opsional)
# Set ke "true" jika mau log setiap sinyal BUY/SELL/HOLD
SIGNALS_LOG=false

# ─── RAILWAY DEPLOYMENT ───────────────────────────────────
# Tidak perlu diisi manual — Railway otomatis inject PORT
# PORT=3000
# NODE_ENV=production

TIME_WARN_MINUTES=20
TIME_CLOSE_MINUTES=45
